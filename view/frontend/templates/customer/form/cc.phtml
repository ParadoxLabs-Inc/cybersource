<?php
/** @var \ParadoxLabs\TokenBase\Block\Customer\Form $block */
/** @var \Magento\Framework\Escaper $escaper */

use Magento\Customer\Helper\Address;
use Magento\Directory\Helper\Data;

?>
<?php $code = $escaper->escapeHtmlAttr($block->getCode()); ?>

<div class="block-title">
    <h2>
        <?php if ($block->isEdit()): ?>
            <?= $escaper->escapeHtml(__('Editing %1', $block->getCard()->getLabel())) ?>
        <?php else: ?>
            <?= $escaper->escapeHtml(__('Add A Credit Card')) ?>
        <?php endif; ?>
    </h2>
</div>

<form action="<?= $escaper->escapeHtmlAttr(
    $block->getAction()
) ?>" method="post" id="form-validate" class="checkout-payment-method payment_form_<?= /* @noEscape */
$code ?>" data-hasrequired="<?= $escaper->escapeHtmlAttr(__('* Required Fields')) ?>">
    <?= /* @noEscape */
    $block->getBlockHtml('formkey') ?>
    <input type="hidden" name="card_id" value="<?= $block->getCard()->getId() ? $escaper->escapeHtmlAttr(
        $block->getCard()->getHash()
    ) : '' ?>"/>
    <input type="hidden" name="method" value="<?= /* @noEscape */
    $code ?>"/>
    <input type="hidden" name="source" value="paymentinfo"/>
    <fieldset class="fieldset address">
        <legend class="legend"><span><?= $escaper->escapeHtml(__('Cardholder Information')) ?></span></legend>
        <br>

        <?= /* @noEscape */
        $block->getNameBlockHtml() ?>
        <div class="field company">
            <label class="label" for="company"><span><?= $escaper->escapeHtml(__('Company')) ?></span></label>
            <div class="control">
                <input type="text" name="billing[company]" id="company" title="<?= $escaper->escapeHtmlAttr(
                    __('Company')
                ) ?>" value="<?= $escaper->escapeHtmlAttr(
                    $block->getAddress()->getCompany()
                ) ?>" class="input-text <?= $escaper->escapeHtmlAttr(
                    $this->helper(Address::class)->getAttributeValidationClass('company')
                ) ?>">
            </div>
        </div>
        <?php $phoneValidation = $this->helper(Address::class)->getAttributeValidationClass(
            'telephone'
        ); ?>
        <div class="field telephone<?php if (mb_strpos((string)$phoneValidation, 'required')
            !== false): ?> required<?php endif; ?>">
            <label class="label" for="telephone"><span><?= $escaper->escapeHtml(__('Phone Number')) ?></span></label>
            <div class="control">
                <input type="text" name="billing[telephone]" value="<?= $escaper->escapeHtmlAttr(
                    $block->getAddress()->getTelephone()
                ) ?>" title="<?= $escaper->escapeHtmlAttr(
                    __('Phone Number')
                ) ?>" class="input-text <?= $escaper->escapeHtmlAttr($phoneValidation) ?>" id="telephone">
            </div>
        </div>
    </fieldset>
    <fieldset class="fieldset address">
        <legend class="legend"><span><?= $escaper->escapeHtml(__('Cardholder Address')) ?></span></legend>
        <br>

        <?php $_streetValidationClass = $escaper->escapeHtmlAttr(
            $this->helper(Address::class)->getAttributeValidationClass('street')
        ); ?>
        <div class="field street required">
            <label for="street" class="label"><span><?= $escaper->escapeHtml(__('Street')) ?></span></label>
            <div class="control">
                <input type="text" name="billing[street][]" value="<?= $escaper->escapeHtmlAttr(
                    $block->getStreetLine(1)
                ) ?>" title="<?= $escaper->escapeHtmlAttr(
                    __('Street Address')
                ) ?>" id="street" class="input-text <?= /* @noEscape */
