                <div class="nested">
                    <?php $_streetValidationClass = trim(str_replace('required-entry', '', $_streetValidationClass)); ?>
                    <?php /** NB: Secure Acceptance only supports 2 street lines according to documentation */ ?>
                    <?php for ($_i = 1,
                               $_n = min(2, $this->helper(Address::class)->getStreetLines());
                               $_i < $_n; $_i++): ?>
                        <?php $lineNo = (int)($_i + 1); ?>
                        <div class="field additional">
                            <label class="label" for="street_<?= /* @noEscape */
                            $lineNo ?>">
                                <span><?= $escaper->escapeHtml(__('Street Address %1', $lineNo)) ?></span>
                            </label>
                            <div class="control">
                                <input type="text" name="billing[street][]" value="<?= $escaper->escapeHtmlAttr(
                                    $block->getStreetLine($lineNo)
                                ) ?>" title="<?= $escaper->escapeHtmlAttr(
                                    __('Street Address %1', $lineNo)
                                ) ?>" id="street_<?= /* @noEscape */
                                $lineNo ?>" class="input-text <?= /* @noEscape */
                                $_streetValidationClass ?>">
                            </div>
                        </div>
                    <?php endfor; ?>
                </div>
            </div>
        </div>
        <div class="field city required">
            <label class="label" for="city"><span><?= $escaper->escapeHtml(__('City')) ?></span></label>
