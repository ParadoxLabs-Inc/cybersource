                <input type="text" name="billing[city]" value="<?= $escaper->escapeHtmlAttr(
                    $block->getAddress()->getCity()
                ) ?>" title="<?= $escaper->escapeHtmlAttr(__('City')) ?>" class="input-text <?= $escaper->escapeHtmlAttr(
                    $this->helper(Address::class)->getAttributeValidationClass('city')
                ) ?>" id="city">
            </div>
        </div>
        <div class="field region required">
            <label class="label" for="region-id"><span><?= $escaper->escapeHtml(__('State/Province')) ?></span></label>
            <div class="control">
                <select id="region-id" name="billing[region_id]" title="<?= $escaper->escapeHtmlAttr(
                    __('State/Province')
                ) ?>" class="validate-select" <?= (!$block->getConfig('general/region/display_all'))
                    ? ' disabled="disabled"' : '' ?>>
                    <option value=""><?= $escaper->escapeHtml(
                            __('Please select a region, state or province.')
                        ) ?></option>
                </select>
                <input type="text" id="region" name="billing[region]" value="<?= $escaper->escapeHtmlAttr(
                    $block->getRegion()
                ) ?>" title="<?= $escaper->escapeHtmlAttr(
                    __('State/Province')
                ) ?>" class="input-text <?= $escaper->escapeHtmlAttr(
                    $this->helper(Address::class)->getAttributeValidationClass('region')
                ) ?>"<?= (!$block->getConfig('general/region/display_all')) ? ' disabled="disabled"' : '' ?>/>
            </div>
        </div>
        <div class="field zip required">
            <label class="label" for="zip"><span><?= $escaper->escapeHtml(__('Zip/Postal Code')) ?></span></label>
            <div class="control">
                <input type="text" name="billing[postcode]" value="<?= $escaper->escapeHtmlAttr(
                    $block->getAddress()->getPostcode()
                ) ?>" title="<?= $escaper->escapeHtmlAttr(
                    __('Zip/Postal Code')
                ) ?>" id="zip" class="input-text validate-zip-international <?= $escaper->escapeHtmlAttr(
                    $this->helper(Address::class)->getAttributeValidationClass('postcode')
                ) ?>">
            </div>
        </div>
        <div class="field country required">
            <label class="label" for="country"><span><?= $escaper->escapeHtml(__('Country')) ?></span></label>
            <div class="control">
                <?= /* @noEscape */
                $block->getCountryHtmlSelect($block->getAddress()->getCountryId(), 'billing[country_id]') ?>
            </div>
        </div>
    </fieldset>
    <div class="actions-toolbar address">
        <div class="primary">
            <button type="button" class="action primary" id="submit-address">
                <span><?= $escaper->escapeHtml(__('Confirm Address')) ?></span>
            </button>
        </div>
    </div>
    <fieldset class="fieldset address">
        <legend class="legend"><span><?= $escaper->escapeHtml(__('Payment Information')) ?></span></legend>
        <br>

        <div class="field">
            <p><?= $escaper->escapeHtml(__('Please confirm your address to enter payment info.')) ?></p>
        </div>
    </fieldset>
    <fieldset class="fieldset payment toggle">
        <legend class="legend"><span><?= $escaper->escapeHtml(__('Cardholder Information')) ?></span></legend>
        <br>

        <div class="field" id="<?= /* @noEscape */
        $code ?>-address">
            <address></address>
            <button type="button" class="action" id="edit-address">
                <span><?= $escaper->escapeHtml(__('Edit')) ?></span>
            </button>
        </div>
    </fieldset>
    <fieldset class="fieldset payment toggle <?= /* @noEscape */
    $code ?>">
        <div class="field required">
            <div class="control">
                <iframe src="about:blank" id="<?= /* @noEscape */
                $code ?>_iframe" name="<?= /* @noEscape */
                $code ?>_iframe"></iframe>
            </div>
        </div>
    </fieldset>
</form>
<script type="text/x-magento-init">
    {
        "#form-validate": {
            "validation": {},
            "cybersourcePaymentInfoForm": {
                "target": "<?= /* @noEscape */
    $code ?>_iframe",
                "paramUrl": "<?= $escaper->escapeJs($block->getUrl('pdl_cybs/secureAccept/getParams')) ?>",
                "successUrl": "<?= $escaper->escapeJs($block->getUrl('*/*', ['method' => $code])) ?>"
            }
        },
        "#country": {
            "regionUpdater": {
                "optionalRegionAllowed": <?= ($block->getConfig('general/region/display_all') ? 'true' : 'false') ?>,
                "regionListId": "#region-id",
                "regionInputId": "#region",
                "postcodeId": "#zip",
                "form": "#form-validate",
                "regionJson": <?= /* @noEscape */
    $this->helper(Data::class)->getRegionJson() ?>,
                "defaultRegion": "<?= (int)$block->getRegionId() ?>",
                "countriesWithOptionalZip": <?= /* @noEscape */
    $this->helper(Data::class)->getCountriesWithOptionalZip(true) ?>
    }
}
}
</script>
