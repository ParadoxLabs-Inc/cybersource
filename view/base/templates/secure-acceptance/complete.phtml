<?php /** @var \ParadoxLabs\CyberSource\Block\Secureaccept\Complete $block */

use Magento\Framework\View\Helper\SecureHtmlRenderer; ?>
<?php
$message = [
    'success' => false,
    'canceled' => false,
    'error' => '',
    'card' => [],
];

try {
    $card = $block->getCard();

    $message['success'] = true;
    $message['card']    = [
        'id' => $card->getHash(),
        'label' => $card->getLabel(),
        'selected' => false,
        'new' => true,
        'type' => $card->getType(),
        'cc_bin' => $card->getAdditional('cc_bin'),
        'cc_last4' => $card->getAdditional('cc_last4'),
    ];
} catch (\Throwable $e) {
    $message['error'] = $e->getMessage();
}
?>
<?php if (!empty($message['error'])): ?>
    <div id="cybersource-complete-results" class="messages">
        <div class="error-msg message-error error message">
            <span><?= $escaper->escapeHtml(__('ERROR: %1', $message['error'])) ?></span>
        </div>
    </div>
<?php else: ?>
    <p id="cybersource-complete-results">
        <?= $escaper->escapeHtml(__('%1 entered successfully.', $card->getLabel())) ?>
    </p>
<?php endif; ?>

<?php $encodedMessage = json_encode($message) ?>
<?php $inlineScript = <<<JS
    /**
     * Show the results after 3 seconds in the event that the communicator fails, but don't otherwise, to avoid visual
     * disruption (blinky page).
     */
    setTimeout(
        function () {
            document.getElementById('cybersource-complete-results').style.display = 'block';
        },
        3000
    );

    /**
     * Send the results out of frame up to the parent page.
     */
    window.top.postMessage({$encodedMessage}, window.location.origin);

    // Backward compat: write to hidden input if it exists (for customized templates)
    try {
        var communicator = window.top.document.getElementById('paradoxlabs_cybersource-communicator');
        if (communicator) {
            communicator.value = '{$encodedMessage}';
            communicator.dispatchEvent(new Event('change'));
        }
    } catch (e) {
        // Cross-origin access will throw; ignore
    }
JS;
?>
<?php if (isset($secureRenderer) && $secureRenderer instanceof SecureHtmlRenderer): ?>
    <?= /* @noEscape */
    $secureRenderer->renderTag('script', [], $inlineScript, false) ?>
<?php else: ?>
    <script><?= /* @noEscape */
        $inlineScript ?></script>
<?php endif; ?>

